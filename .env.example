# LiteLLM proxy reachable over the litellm_internal network
LITELLM_BASE_URL=http://litellm_app:4000
LITELLM_MASTER_KEY=sk-your-litellm-master-key

# Admin login (set strong values in production)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-now

# Random 32+ char string used to sign JWTs
JWT_SECRET=please-generate-a-long-random-string
JWT_EXPIRE_MINUTES=720

# Browser origins allowed by the API (use your NPM-fronted hostname in prod)
CORS_ORIGINS=*
